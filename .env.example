# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For PostgreSQL: postgresql://user:password@localhost:5432/zenico_admin
# For SQLite (development): sqlite:///db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# Email Configuration (Production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=your-email@example.com

# Mail Settings
MAIL_FROM_ADDRESS=noreply@zenico.app
MAIL_FROM_NAME=Zenico

# Microsoft Graph (used by MailService)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Admin notification recipient
ADMIN_NOTIFICATION_EMAIL=team@zenico.app

# URLs
# Base URL of the admin backend (for links in emails)
ADMIN_BASE_URL=https://admin.zenico.app

# Base URL of the public homepage (for redirects + unsubscribe links)
FRONTEND_BASE_URL=https://zenico.app

# Field Encryption Key (for encrypting sensitive data like Stripe keys)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# AI Provider Configuration
# OpenAI API Key (for AI proxy endpoint)
OPENAI_API_KEY=sk-...

# Anthropic API Key (for AI proxy endpoint)
ANTHROPIC_API_KEY=sk-ant-...

# Default AI Provider (anthropic or openai)
AI_DEFAULT_PROVIDER=anthropic

# Django Log Level (Production)
DJANGO_LOG_LEVEL=INFO

# Provisioning Agent Token (shared secret for the zenico-provisioner agent)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
PROVISIONING_AGENT_TOKEN=

# Sentry Configuration (Optional - only set if you want to use Sentry)
# Get your DSN from https://sentry.io/ after creating a project
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
